msgid "Gift Card"
msgstr "بطاقة هدية"

msgid "Redeem your spa gift card"
msgstr "استرد بطاقة هدية السبا الخاصة بك"

msgid "All rights reserved."
msgstr "جميع الحقوق محفوظة."

msgid "Your Gift Card"
msgstr "بطاقة الهدية الخاصة بك"

#, python-format
msgid "You've received a spa gift card for %(service)s at %(spa)s"
msgstr "لقد تلقيت بطاقة هدية سبا لـ %(service)s في %(spa)s"

