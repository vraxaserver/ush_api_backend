msgstr "هدية خاصة من %(sender)s"

msgid "Enjoy Your Gift"
msgstr "استمتع بهديتك"

msgid "To start enjoying this exclusive spa experience, please download our mobile app and log in or complete your registration. Your relaxation awaits!"
msgstr "لبدء الاستمتاع بتجربة السبا الحصرية هذه، يرجى تنزيل تطبيقنا وتسجيل الدخول أو إكمال تسجيلك. استرخاؤك في انتظارك!"

msgid "Download App"
msgstr "تنزيل التطبيق"

msgid "WhatsApp Us"
msgstr "تواصل معنا عبر واتساب"

#, python-format
msgid "Dear %(recipient)s,"
msgstr "عزيزي %(recipient)s،"

